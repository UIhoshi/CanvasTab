{
  "manifest_version": 3,
  "name": "CanvasTab: Wallpaper Canvas & Bookmark Organizer",
  "version": "1.2.1",
  "description": "CanvasTab is a minimal, aesthetic card-style bookmarks manager and customizable New Tab dashboard.",
  "permissions": [
    "bookmarks",
    "favicon",
    "history",
    "search",
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icon16.png",
    "32": "icon32.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "打开书签看板",
    "default_icon": {
      "16": "icon16.png",
      "32": "icon32.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "chrome_url_overrides": {
    "newtab": "dashboard.html"
  }
}
